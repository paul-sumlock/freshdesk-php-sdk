{
    "name": "seyvillas/freshdesk-php-sdk",
    "description": "PHP SDK for the Freshdesk API (v2) for PHP 8.4",
    "type": "library",
    "homepage": "https://github.com/seyvillas/freshdesk-php-sdk",
    "keywords": ["freshdesk", "customer service", "support", "help desk", "api"],
    "license": "MIT",
    "authors": [
        {
            "name": "Miroslav Koula",
            "email": "miroslav.koula@seyvillas.com",
            "homepage": "https://github.com/elcheco"
        },
        {
            "name": "Matthew Clarkson",
            "email": "mpclarkson@hilenium.com",
            "homepage": "http://mpclarkson.github.io/"
        }
    ],
    "require": {
        "php": ">=8.4",
        "guzzlehttp/guzzle": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {"Freshdesk\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": { "Freshdesk\\tests\\": "tests/" }
    }
}
